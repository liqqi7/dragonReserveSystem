/**
 * swiper-header-sync.wxs
 * Header strip 与 timeline swiper 的物理同步（渲染线程）。
 *
 * 设计前提（新架构）：
 *   - timeline swiper 使用「长 page 列表 + current 累加」模式，永不重建/重置 current
 *   - transition 含用户拖动与周条触发的程序化连扫；后者用 suppressDragPreview 避免误改周条高亮
 *   - strip transform = baseOffset - dx，再按条带宽度与 3 列可视宽 clamp，避免异常 dx 把标题整体移出裁剪区
 *
 * 状态：
 *   - frozen（来自 data-frozen）：JS 层做边界扩展时短暂打开，跳过本帧 setStyle
 *   - suppressDragPreview（来自 data-suppress-drag-preview）：连扫动画中跳过周条高亮 callMethod
 *
 * 不再需要：_pendingBaseOffset / _frozenForRebuild / APPLY_THRESHOLD 等补丁状态
 */

var _logCount = 0;

function onTransition(event, ownerInstance) {
  // JS 层主动冻结（如边界扩展），本帧不做同步
  if (event.instance.getDataset().frozen) return;

  var dx = event.detail.dx;
  if (dx === undefined || dx === null) return;

  var strip = ownerInstance.selectComponent('.day-titles-strip');
  if (!strip) return;

  var ds = strip.getDataset();
  var baseOffset = parseFloat(ds.baseOffsetPx);
  if (isNaN(baseOffset)) return;

  var cellW = parseFloat(ds.cellWidthPx);
  if (isNaN(cellW) || cellW <= 0) cellW = 112;

  // 必须在阈值判断前读 suppressDragPreview：
  // 周条翻周是7天程序化动画，dx 最大达 7×cellW，必须绕过阈值才能平滑跟随
  var dsSwiper = event.instance.getDataset();
  var sup = dsSwiper.suppressDragPreview;
  var suppressPreview = sup === true || sup === 1 || sup === 'true';

  // 硬阈值：过滤 swiper 重挂载/初始化时产生的虚假大位移（约 15×cellW 或 22×cellW）
  // suppressPreview=true（周条翻周动画）：7天动画最大 dx≈7×cellW；超出为虚假跳变，丢弃
  // suppressPreview=false（用户手势）：单次手势最多跨 3 列；超出即丢弃
  var MAX_VALID_DX = suppressPreview ? 7 * cellW : 3 * cellW;
  if (Math.abs(dx) > MAX_VALID_DX) return;

  var stripW = parseFloat(ds.stripWidthPx);
  var viewCols = 3;
  var viewW = viewCols * cellW;
  // 条带宽度未就绪时（stripW 无效）：勿用 minTranslate=0 做下界，否则 -3367 会被钳到 0，与 swiper 严重错位（表头空白/错日）
  var canClampStrip = !isNaN(stripW) && stripW > viewW && viewW > 0;
  var finalOffset = baseOffset - dx;
  if (finalOffset > 0) finalOffset = 0;
  if (canClampStrip) {
    var minTranslate = -(stripW - viewW);
    if (finalOffset < minTranslate) finalOffset = minTranslate;
  } else {
    // stripW 未就绪时，suppressPreview 动画不额外钳制 dx（让大范围动画通过）
    if (!suppressPreview) {
      var maxGui = 2 * cellW;
      if (dx > maxGui) dx = maxGui;
      if (dx < -maxGui) dx = -maxGui;
      finalOffset = baseOffset - dx;
      if (finalOffset > 0) finalOffset = 0;
    }
  }

  // 周条驱动的时间格连扫：JS 已写好高亮，transition 的 dx 仍会多格变化；
  // 仅跳过周条预览 callMethod，吸顶条仍用 baseOffset - dx。
  if (!suppressPreview) {
    ownerInstance.callMethod('onTimelineDragPreview', {
      dx: dx,
      swiperCurrent: dsSwiper.swiperCurrent
    });
  }

  _logCount++;
  if (_logCount <= 5 || (_logCount % 15 === 0 && _logCount <= 105)) {
    ownerInstance.callMethod('onWxsTransitionLog', {
      dx: dx,
      baseOffsetPx: baseOffset,
      offset: finalOffset,
      n: _logCount
    });
  }

  strip.setStyle({ transform: 'translateX(' + finalOffset + 'px)' });
}

module.exports = {
  onTransition: onTransition
};
