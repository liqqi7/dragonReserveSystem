.event-text {
  min-width: 0;
  font-size: 9px;
  line-height: 13.5px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.event-status {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 24rpx;
}

.calendar-state {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx;
  box-sizing: border-box;
  background: #ffffff;
  text-align: center;
}

.state-title {
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 700;
  color: #101828;
}

.state-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #6a7282;
}

.state-btn {
  margin-top: 36rpx;
  min-width: 192rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #ff001f;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 72rpx;
  padding: 0 36rpx;
}

.state-btn::after {
  border: 0;
}

.empty-overlay {
  position: absolute;
  left: 100rpx;
  right: 0;
  top: 220rpx;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}
