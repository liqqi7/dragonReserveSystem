page {
  background-color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.info-panel {
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.distance {
  font-size: 24rpx;
  color: #999;
}

.map {
  flex: 1;
  width: 100%;
}

.footer {
  padding: 16rpx 24rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.btn.default {
  background-color: #f0f0f0;
  color: #333;
}

