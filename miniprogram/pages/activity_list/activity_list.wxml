<view class="container {{isGuest ? 'guest-mode' : ''}}">
  <!-- 游客缺省态 -->
  <view wx:if="{{isGuest}}" class="guest-empty-state">
    <image class="guest-empty-icon" src="/images/activity-empty-icon.gif" mode="aspectFit" />
    <text class="guest-empty-text">未查询到您的冒险者工会归属</text>
    <text class="guest-empty-text">请前往「我的」进行登录</text>
  </view>

  <!-- 已授权用户内容 -->
  <block wx:else>
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="请输入活动名称"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- 状态筛选 -->
  <view class="filter-tabs">
    <view
      wx:for="{{['我参与的', '未开始', '进行中', '已结束', '已取消', '全部']}}"
      wx:key="*this"
      class="filter-tab {{selectedFilter === item ? 'active' : ''}}"
      data-filter="{{item}}"
      bindtap="onFilterChange"
    >
      {{item}}
    </view>
  </view>

  <!-- 活动列表 -->
  <view wx:if="{{filteredList.length === 0}}" class="empty-state">
    <image class="empty-icon" src="/images/activity-empty-default.gif" mode="aspectFit" />
    <text class="empty-text">{{searchKeyword ? '未找到相关活动' : '暂无活动'}}</text>
  </view>

  <view wx:else class="activity-list {{isAdmin ? 'has-fixed-btn' : ''}}">
    <view
      wx:for="{{filteredList}}"
      wx:key="_id"
      class="activity-card"
      bindtap="showDetail"
      data-activity="{{item}}"
    >
      <view class="card-body">
        <!-- 活动标题和状态 -->
        <view class="activity-header">
          <view class="activity-title">{{item.name}}</view>
          <view class="status-badge {{item.status === '进行中' ? 'status-active' : (item.status === '已取消' ? 'status-cancelled' : (item.status === '未开始' ? 'status-pending' : 'status-ended'))}}">
            {{item.status}}
          </view>
        </view>

        <!-- 活动信息 -->
        <view class="activity-meta {{!(isAdmin || item.status === '未开始' || item.status === '进行中') ? 'no-actions' : ''}}">
          <view wx:if="{{item.remark}}" class="meta-item">
            <text class="meta-icon">✏️</text>
            <text class="meta-text">活动备注：{{item.remark}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-icon">🕐</text>
            <text class="meta-text">开始时间：{{item.startTime || item.date}}</text>
          </view>
          <view wx:if="{{item.signupDeadline}}" class="meta-item signup-deadline-row">
            <text class="meta-icon">⏰</text>
            <text class="meta-text">报名截止：{{item.signupDeadline}}</text>
          </view>
          <view class="meta-item participants-row">
            <view class="participants-content">
              <view class="avatar-list" wx:if="{{item.avatarList && item.avatarList.length}}">
                <view
                  wx:for="{{item.avatarList}}"
                  wx:for-item="avatarItem"
                  wx:for-index="ai"
                  wx:key="ai"
                  class="avatar-wrapper {{avatarItem.isDefault ? 'avatar-default' : ''}}"
                >
                  <image
                    class="avatar-img"
                    src="{{avatarItem.url}}"
                    mode="aspectFill"
                    binderror="onAvatarError"
                    data-index="{{ai}}"
                    data-activity-id="{{item._id}}"
                  />
                </view>
              </view>
              <!-- 有报名 + 头像：额外加一个类做光学对齐 -->
              <text class="meta-text participants-text participants-text-with-avatar" wx:if="{{item.participants.length > 0}}">
                等 {{item.participants.length}} 人报名
              </text>
              <text class="meta-text participants-text" wx:else>暂无报名</text>
            </view>
          </view>
        </view>

        <!-- 操作按钮：仅在有可显示按钮时渲染，避免非管理员/已结束时留空 -->
        <view wx:if="{{isAdmin || item.status === '未开始' || item.status === '进行中'}}" class="card-actions">
          <button
            wx:if="{{(item.status === '未开始' || item.status === '进行中') && !item.hasSignedUp && !item.isSignupClosed}}"
            class="action-btn primary"
            catchtap="directSignup"
            data-activity="{{item}}"
          >报名</button>
          <button
            wx:elif="{{(item.status === '未开始' || item.status === '进行中') && !item.hasSignedUp && item.isSignupClosed}}"
            class="action-btn default"
            disabled="true"
          >报名已截止</button>
          <button
            wx:if="{{item.hasSignedUp && item.hasCheckedIn}}"
            class="action-btn default"
            disabled="true"
          >已签到</button>
          <button
            wx:if="{{item.hasSignedUp && !item.hasCheckedIn && (item.status === '进行中' || item.status === '未开始')}}"
            class="action-btn primary"
            catchtap="checkinActivity"
            data-activity="{{item}}"
          >签到</button>
          <button
            wx:if="{{isAdmin}}"
            class="action-btn default"
            catchtap="showEditModal"
            data-activity="{{item}}"
          >编辑</button>
          <button
            wx:if="{{isAdmin}}"
            class="action-btn danger"
            catchtap="deleteActivity"
            data-activity="{{item}}"
          >删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 编辑/创建弹窗 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="closeEditModal" catchtouchmove="stopPropagation">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>{{currentActivity ? '编辑活动' : '新增活动'}}</text>
        <text class="close-btn" bindtap="closeEditModal">×</text>
      </view>

      <view class="modal-body">
        <view class="form-item">
          <view class="label">开始时间：</view>
          <view class="datetime-picker-wrapper">
            <picker mode="date" value="{{editForm.startDate}}" bindchange="onStartDateChange">
              <view class="picker datetime-date">{{editForm.startDate || '请选择日期'}}</view>
            </picker>
            <picker mode="time" value="{{editForm.startTime}}" bindchange="onStartTimeChange">
              <view class="picker datetime-time">{{editForm.startTime || '请选择时间'}}</view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="label">结束时间：</view>
          <view class="datetime-picker-wrapper">
            <picker mode="date" value="{{editForm.endDate}}" bindchange="onEndDateChange">
              <view class="picker datetime-date">{{editForm.endDate || '请选择日期'}}</view>
            </picker>
            <picker mode="time" value="{{editForm.endTime}}" bindchange="onEndTimeChange">
              <view class="picker datetime-time">{{editForm.endTime || '请选择时间'}}</view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="label">报名截止：</view>
          <view class="datetime-picker-wrapper">
            <picker mode="date" value="{{editForm.signupDeadlineDate}}" bindchange="onSignupDeadlineDateChange">
              <view class="picker datetime-date">{{editForm.signupDeadlineDate || '请选择日期'}}</view>
            </picker>
            <picker mode="time" value="{{editForm.signupDeadlineTime}}" bindchange="onSignupDeadlineTimeChange">
              <view class="picker datetime-time">{{editForm.signupDeadlineTime || '请选择时间'}}</view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="label">活动名称：</view>
          <input
            class="input"
            placeholder="请输入活动名称"
            value="{{editForm.name}}"
            bindinput="onEditFormChange"
            data-field="name"
            adjust-position="{{false}}"
          />
        </view>

        <view class="form-item">
          <view class="label">活动地点：</view>
          <view class="picker {{locationDisabled ? 'picker-disabled' : ''}}" bindtap="onChooseLocation">
            {{editForm.locationName || '请选择活动位置'}}
          </view>
        </view>

        <view class="form-item">
          <view class="label">活动备注：</view>
          <textarea
            class="textarea"
            placeholder="请输入备注（可选）"
            value="{{editForm.remark}}"
            bindinput="onEditFormChange"
            data-field="remark"
            adjust-position="{{true}}"
            cursor-spacing="120"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn default" bindtap="closeEditModal">取消</button>
        <button wx:if="{{isAdmin && currentActivity && currentActivity.status !== '已取消'}}" class="btn danger" bindtap="cancelActivity">取消活动</button>
        <button class="btn primary" bindtap="saveActivity">保存</button>
      </view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view wx:if="{{showDetailModal}}" class="modal-overlay" bindtap="closeDetailModal" catchtouchmove="stopPropagation">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>活动详情</text>
        <text class="close-btn" bindtap="closeDetailModal">×</text>
      </view>

      <view class="modal-body">
        <view class="detail-item">
          <text class="label">活动名称：</text>
          <text>{{detailActivity.name}}</text>
        </view>
        <view class="detail-item">
          <text class="label">开始时间：</text>
          <text>{{detailActivity.startTime || detailActivity.date + ' 00:00'}}</text>
        </view>
        <view class="detail-item">
          <text class="label">结束时间：</text>
          <text>{{detailActivity.endTime || detailActivity.date + ' 01:00'}}</text>
        </view>
        <view class="detail-item">
          <text class="label">报名截止：</text>
          <text>{{detailActivity.signupDeadline}}</text>
        </view>
        <view class="detail-item">
          <text class="label">活动状态：</text>
          <text>{{detailActivity.status}}</text>
        </view>
        <view wx:if="{{detailActivity.remark}}" class="detail-item">
          <text class="label">活动备注：</text>
          <text>{{detailActivity.remark}}</text>
        </view>

        <view wx:if="{{detailActivity.locationName || detailActivity.locationAddress}}" class="detail-item">
          <text class="label">活动地点：</text>
          <text>{{detailActivity.locationName}} {{detailActivity.locationAddress}}</text>
        </view>

        <view class="divider"></view>

        <view class="detail-item">
          <text class="label">已报名人员（{{detailActivity.participants.length}} 人，已签到 {{detailActivity.checkinCount || 0}} 人）：</text>
        </view>
        <view wx:if="{{detailActivity.participants.length === 0}}" class="empty-text">暂无报名人员</view>
        <view wx:else class="participant-list">
          <view
            wx:for="{{detailActivity.participants}}"
            wx:key="index"
            wx:for-item="participant"
            class="participant-item"
          >
            <text class="participant-name">{{participant.name}}<text wx:if="{{participant.checkedInAt}}" class="participant-checkin">（已签到）</text><text wx:elif="{{detailActivity.activityStarted}}" class="participant-pigeon">（鸽子🐦！）</text></text>
            <text wx:if="{{isAdmin || (!detailActivity.signupDeadlinePassed && ((participant.userId && participant.userId === myUserId) || (!participant.userId && participant.name === myNickname)))}}" class="participant-delete" bindtap="removeParticipant" data-name="{{participant.name}}">删除</text>
          </view>
        </view>
      </view>

      <view class="modal-footer detail-footer">
        <block wx:if="{{detailActivity.status === '未开始' || detailActivity.status === '进行中'}}">
          <button
            wx:if="{{!detailActivity.hasSignedUp && !detailActivity.signupDeadlinePassed}}"
            class="btn primary"
            bindtap="detailSignup"
          >报名</button>
          <button
            wx:elif="{{!detailActivity.hasSignedUp && detailActivity.signupDeadlinePassed}}"
            class="btn default"
            disabled="true"
          >报名已截止</button>
          <button
            wx:elif="{{detailActivity.hasSignedUp && !detailActivity.hasCheckedIn}}"
            class="btn primary"
            bindtap="detailCheckin"
          >签到</button>
          <button
            wx:elif="{{detailActivity.hasSignedUp && detailActivity.hasCheckedIn}}"
            class="btn default"
            disabled="true"
          >已签到</button>
        </block>
        <button class="btn default" open-type="share">分享</button>
      </view>
    </view>
  </view>
  </block>
</view>

<!-- 吸底新建活动按钮（仅管理员显示，与列表同层，弹窗遮罩会盖住按钮） -->
<button wx:if="{{isAdmin && !isGuest}}" class="create-btn-fixed" bindtap="showCreateModal">新建活动</button>
