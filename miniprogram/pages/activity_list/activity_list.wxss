page {
  background-color: #ffffff;
}

.container {
  padding: 0;
  background-color: #ffffff;
}

/* 吸底新建活动按钮（与列表同层，弹窗遮罩 z-index:1000 会盖住按钮） */
button.create-btn-fixed {
  position: fixed !important;
  bottom: 32rpx !important;
  left: 50% !important;
  transform: translateX(-50%) !important;
  z-index: 100 !important;
  width: auto !important;
  min-width: 140rpx !important;
  max-width: 268rpx !important;
  padding: 20rpx 64rpx !important;
  font-size: 28rpx !important;
  color: #ffffff !important;
  background-color: #007aff !important;
  border: none !important;
  border-radius: 999rpx !important;
  line-height: 1.5 !important;
  font-weight: 500 !important;
  box-shadow: 0 4rpx 20rpx rgba(0, 122, 255, 0.3) !important;
  box-sizing: border-box !important;
  margin: 0 !important;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background-color: #ffffff;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 20rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.filter-tab.active {
  color: #007aff;
  background-color: #e6f3ff;
  font-weight: 600;
}

/* 空状态：占满内容区并垂直居中 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 72vh; /* 使块占满中间区域，缺省图与文案处于中间 */
  padding: 24rpx;
  padding-bottom: 240rpx; /* 为底部固定按钮留出空间 */
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 活动列表 */
.activity-list {
  padding: 24rpx;
  padding-bottom: 120rpx; /* 管理员：为底部固定「新建活动」按钮留出空间 */
}
.activity-list:not(.has-fixed-btn) {
  padding-bottom: 8rpx; /* 非管理员无固定按钮，最小下边距（最后一个卡片已有 margin-bottom: 24rpx 提供主要间距） */
}

.activity-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 卡片内容 */
.card-body {
  padding: 24rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  margin-left: 12rpx;
}

.status-badge.status-active {
  background-color: #e6f9f0;
  color: #07c160;
}

.status-badge.status-pending {
  background-color: #e6f3ff;
  color: #007aff;
}

.status-badge.status-ended,
.status-badge.status-cancelled {
  background-color: #f5f5f5;
  color: #999;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* 活动信息 */
.activity-meta {
  margin-bottom: 20rpx;
}
.activity-meta.no-actions {
  margin-bottom: 0; /* 无按钮时移除底部间距，避免卡片底部留白过大 */
}

.signup-deadline-row .meta-icon {
  font-size: 24rpx;
}

.signup-deadline-row .meta-text {
  font-size: 26rpx;
  color: #666;
}

.meta-item.signup-deadline-row {
  margin-bottom: 32rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}
/* 无按钮时，最后一个 meta-item（participants-row）的 margin-bottom 也移除，使上下边距一致 */
.activity-meta.no-actions .meta-item:last-child {
  margin-bottom: 0;
}

.meta-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  width: 32rpx;
  text-align: center;
}

.meta-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 报名头像 + 文案这一行 */
.participants-row {
  border-top: 1rpx solid #eee;      /* 和上面的活动信息做一个分割线 */
  margin-top: 12rpx;
  padding-top: 12rpx;
  min-height: 48rpx;                /* 确保有足够高度显示文字 */
  overflow: visible;                 /* 确保 transform 后的文字不被裁剪 */
}

.participants-row .participants-content {
  display: flex;
  align-items: center;              /* 垂直居中 */
  justify-content: center;          /* 整块在卡片内水平居中 */
}

.avatar-list {
  display: flex;
  align-items: center;              /* 多个头像时也居中 */
  margin-right: 12rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: -8rpx;
  width: 48rpx;
  height: 48rpx;
}

.avatar-img {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  background-color: #f5f5f5;
  display: block;
  position: relative;
  z-index: 0;
}

/* 默认头像：添加阴影人像图标，和加载态区分开 */
.avatar-default::before {
  content: '👤';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.25);
  z-index: 2;
  pointer-events: none;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.participants-text {
  font-size: 24rpx;
  color: #666;
  line-height: normal;              /* 基础行高：给“暂无报名”等普通文案用 */
}

/* 仅有头像 + 报名人数这一种情况，做光学上移，不影响“暂无报名” */
.participants-text-with-avatar {
  margin-left: 16rpx;               /* 抵消最后一个头像的 -8rpx 再留一点空隙 */
  transform: translateY(-14rpx);    /* 你现在调好的上移值，保持不变 */
}

/* 覆盖 meta-text 的 flex:1 和 overflow，让这一行整体真正居中 */
.participants-row .participants-text {
  flex: none;
  overflow: visible;
  white-space: normal;
  text-align: center;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-direction: row;
  justify-content: flex-start;
  flex-wrap: nowrap;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 1;
}

.action-btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.action-btn.default {
  background-color: #f0f0f0;
  color: #333;
}

.action-btn.danger {
  background-color: #fa5151;
  color: #ffffff;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 24rpx;
}

.edit-modal-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.edit-modal-panel {
  position: relative;
  z-index: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 90%;
  height: 80vh;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.edit-modal-header,
.edit-modal-footer {
  flex-shrink: 0;
}

.edit-modal-body-wrapper {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.edit-modal-body {
  height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.detail-modal-body {
  padding-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  border-top: 1rpx solid #eee;
  gap: 16rpx;
}

.modal-footer .btn {
  flex: 1;
  margin: 0;
}

.modal-footer.detail-footer {
  flex-wrap: wrap;
  padding-top: 20rpx;
  background-color: #ffffff;
}

.modal-footer.detail-footer .btn {
  min-width: 120rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.textarea {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  min-height: 120rpx;
}

.picker {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  color: #333;
}

.picker-disabled {
  background-color: #f5f5f5;
  color: #999;
}

/* 日期时间选择器布局 */
.datetime-picker-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.datetime-picker-wrapper .datetime-date {
  flex: 1;
}

.datetime-picker-wrapper .datetime-time {
  flex: 1;
}

.detail-item {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-item .label {
  color: #999;
  margin-right: 8rpx;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 24rpx 0;
}

.participant-list {
  margin-top: 8rpx;
}

/* 报名人员列表滚动容器（详情弹窗内） */
.participant-scroll {
  margin-top: 8rpx;
  max-height: 360rpx;
  box-sizing: border-box;
  padding-bottom: 16rpx;
}

.participant-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.participant-actions {
  display: flex;
  align-items: center;
}

.participant-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.participant-checkin {
  font-size: 24rpx;
  color: #07c160;
  margin-left: 8rpx;
}

.participant-pigeon {
  font-size: 24rpx;
  color: #fa9d3b;
  margin-left: 8rpx;
}

.participant-delete {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #fa5151;
  padding: 6rpx 12rpx;
  background-color: #fff5f5;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.participant-retro-checkin {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #07c160;
  padding: 6rpx 12rpx;
  background-color: #e6f9ed;
  border-radius: 8rpx;
}

.btn {
  width: 100%;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.btn.default {
  background-color: #f0f0f0;
  color: #333;
}

.btn.danger {
  background-color: #fa5151;
  color: #ffffff;
}
