/* ── 大卡片毛玻璃底部 ── */
.glass-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.4) 100%);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  z-index: 3;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

.glass-name {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6px;
}

.glass-remark {
  display: block;
  font-size: 12px;
  font-weight: 400;
  color: rgba(255,255,255,0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6px;
}

.glass-meta-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 6px;
}

.glass-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
  overflow: hidden;
}

.glass-meta-icon {
  font-size: 22rpx;
  flex-shrink: 0;
}

.glass-meta-text {
  font-size: 12px;
  font-weight: 400;
  color: rgba(255,255,255,0.85);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
}

/* ── 自定义底部 Tab ── */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  gap: 32rpx;
}

.tab-items-wrap {
  display: flex;
  align-items: center;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: inset 0 -2rpx 4rpx rgba(0,0,0,0.12), inset 0 2rpx 2rpx #fff;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 170rpx;
  height: 108rpx;
  border-radius: 999rpx;
  gap: 6rpx;
  transition: background-color 0.15s ease;
}

.tab-item-active {
  background-color: rgba(232,233,233,0.5);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-label {
  font-size: 20rpx;
  color: #1a191a;
}

.tab-label-active {
  color: #ff001f;
}

