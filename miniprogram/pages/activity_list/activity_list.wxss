page {
  background-color: #f5f5f5;
}

.container {
  padding: 0;
  background-color: #ffffff;
}

/* 顶部操作栏 */
.top-bar {
  padding: 20rpx 24rpx;
  background-color: #ffffff;
}

.top-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.icon-btn {
  font-size: 40rpx;
  line-height: 1;
  padding: 8rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  padding: 16rpx 20rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 20rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.filter-tab.active {
  color: #007aff;
  background-color: #e6f3ff;
  font-weight: 600;
  position: relative;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #007aff;
  border-radius: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 活动列表 */
.activity-list {
  padding: 24rpx;
}

.activity-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 卡片内容 */
.card-body {
  padding: 24rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  margin-left: 12rpx;
}

.status-badge.status-active {
  background-color: #e6f9f0;
  color: #07c160;
}

.status-badge.status-ended {
  background-color: #f5f5f5;
  color: #999;
}

.status-badge.status-cancelled {
  background-color: #f5f5f5;
  color: #999;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* 活动信息 */
.activity-meta {
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.meta-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  width: 32rpx;
  text-align: center;
}

.meta-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-direction: row;
  justify-content: flex-start;
  flex-wrap: nowrap;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 1;
}

.action-btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.action-btn.default {
  background-color: #f0f0f0;
  color: #333;
}

.action-btn.danger {
  background-color: #fa5151;
  color: #ffffff;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 24rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  border-top: 1rpx solid #eee;
  gap: 16rpx;
}

.modal-footer .btn {
  flex: 1;
  margin: 0;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.textarea {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  min-height: 120rpx;
}

.picker {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  color: #333;
}

.readonly-text {
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #666;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  padding-left: 20rpx;
}

.detail-item {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-item .label {
  color: #999;
  margin-right: 8rpx;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 24rpx 0;
}

.participant-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.participant-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.participant-delete {
  font-size: 24rpx;
  color: #fa5151;
  padding: 6rpx 12rpx;
  background-color: #fff5f5;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

.btn {
  width: 100%;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.btn.default {
  background-color: #f0f0f0;
  color: #333;
}
