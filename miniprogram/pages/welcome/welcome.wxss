page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.auth-card {
  margin-top: 120rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 表单样式，参考 profile 编辑弹窗 */
.form-item {
  margin-bottom: 24rpx;
}

.avatar-form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.avatar-form-row .label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.avatar-edit-wrap {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 48rpx;
  overflow: hidden;
  position: relative;
}

.avatar-edit-btn {
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: none !important;
  width: 96rpx !important;
  height: 96rpx !important;
  min-width: 96rpx !important;
  min-height: 96rpx !important;
  line-height: 96rpx !important;
  border-radius: 48rpx;
  overflow: hidden;
  display: block;
  box-sizing: border-box;
}

.avatar-edit-btn::after {
  border: none;
}

.avatar-edit-img {
  width: 96rpx !important;
  height: 96rpx !important;
  display: block;
  border-radius: 48rpx;
}

.avatar-edit-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 72rpx;
  line-height: 40rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.btn {
  width: 100%;
  margin-top: 8rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.btn.primary.disabled {
  background-color: #c8c8c8;
  color: #ffffff;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
