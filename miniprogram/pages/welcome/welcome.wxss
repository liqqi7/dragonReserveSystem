page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.auth-card {
  margin-top: 120rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 32rpx;
}

.auth-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}

.auth-row .avatar-btn {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-row .avatar-img,
.auth-row .avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.auth-row .avatar-img {
  display: block;
}

.auth-row .avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
  background-color: #eee;
}

.nickname-input {
  flex: 1;
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}

.form-item {
  margin-bottom: 24rpx;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  width: 100%;
  box-sizing: border-box;
}

.btn {
  width: 100%;
  margin-top: 8rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
