<view class="container">
  <view class="card auth-card">
    <view class="title">龙城冒险者工会预约系统</view>
    <view class="subtitle">{{mode === 'register' ? '注册本地账号后进入' : '使用本地账号登录'}}</view>

    <view class="form-item">
      <view class="label">模式</view>
      <view class="mode-switch">
        <button class="btn default small" bindtap="switchMode" data-mode="login">登录</button>
        <button class="btn default small" bindtap="switchMode" data-mode="register">注册</button>
      </view>
    </view>

    <form bindsubmit="onFormSubmit">
      <view class="form-item">
        <view class="label">账号</view>
        <input
          type="text"
          class="input"
          name="username"
          placeholder="请输入登录账号"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>
      <view wx:if="{{mode === 'register'}}" class="form-item">
        <view class="label">昵称</view>
        <input
          type="text"
          class="input"
          name="nickname"
          placeholder="请输入昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>
      <view class="form-item">
        <view class="label">密码</view>
        <input
          password
          class="input"
          name="password"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
      <button class="btn primary {{canSubmit ? '' : 'disabled'}}" form-type="submit" disabled="{{submitting}}">
        {{submitting ? '提交中...' : (mode === 'register' ? '注册并进入' : '登录进入')}}
      </button>
    </form>
  </view>
</view>
