<view class="container">
  <view class="card auth-card">
    <view class="title">龙城冒险者工会预约系统</view>
    <view class="subtitle">请填写头像与昵称后进入</view>

    <form bindsubmit="onFormSubmit">
      <view class="form-item avatar-form-row">
        <view class="label">头像</view>
        <view class="avatar-edit-wrap">
          <button class="avatar-edit-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{avatarUrl}}" class="avatar-edit-img" src="{{avatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar-edit-placeholder">选择头像</view>
          </button>
        </view>
      </view>
      <view class="form-item">
        <view class="label">昵称</view>
        <input
          type="text"
          class="input"
          name="nickname"
          placeholder="请输入昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>
      <button class="btn primary {{canSubmit ? '' : 'disabled'}}" form-type="submit" disabled="{{submitting}}">
        {{submitting ? '登记冒险者信息中...' : '进入'}}
      </button>
    </form>
  </view>
</view>
