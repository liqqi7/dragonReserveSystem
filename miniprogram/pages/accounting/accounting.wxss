page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.picker {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  color: #333;
}

.activity-info {
  margin-top: 8rpx;
  display: flex;
  gap: 16rpx;
}

.info-text {
  font-size: 24rpx;
  color: #999;
}

.participants-header {
  margin-bottom: 8rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.checkbox-label {
  margin-left: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.btn {
  width: 100%;
  margin-top: 8rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 24rpx 0;
}

.list-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 28rpx;
  color: #333;
}

.list-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.summary-header {
  margin-bottom: 16rpx;
}
