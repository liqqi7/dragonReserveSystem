<view class="container {{isGuest ? 'guest-mode' : ''}}">
  <!-- 游客缺省态 -->
  <view wx:if="{{isGuest}}" class="guest-empty-state">
    <image class="guest-empty-icon" src="/images/empty-state-icon.png" mode="aspectFit" />
    <text class="guest-empty-text">未查询到您的冒险者工会归属</text>
    <text class="guest-empty-text">请前往「我的-访问权限」处进行登记🌹</text>
  </view>

  <!-- 已授权用户内容 -->
  <view wx:else class="card">
    <view class="section-title">AA 记账</view>

    <!-- 活动选择器 -->
    <view class="form-item">
      <view class="label">选择活动</view>
      <picker
        mode="selector"
        range="{{activityList}}"
        range-key="name"
        value="{{selectedActivityIndex}}"
        bindchange="onActivityChange"
      >
        <view class="picker">
          {{selectedActivity ? selectedActivity.name : '请选择活动'}}
        </view>
      </picker>
      <view wx:if="{{selectedActivity}}" class="activity-info">
        <text class="info-text">日期：{{selectedActivity.date}}</text>
        <text class="info-text">状态：{{selectedActivity.status}}</text>
      </view>
    </view>

    <view wx:if="{{selectedActivity}}">
      <!-- 当日已报名成员提示 -->
      <view class="form-item">
        <view class="label">参与人员名单</view>
        <view wx:if="{{aaMembers.length === 0}}" class="empty-text">
          该活动暂无报名人员
        </view>
        <view wx:else class="list-sub">
          已报名成员 {{aaMembers.length}} 人，可作为付款人和参与人。
        </view>
      </view>

      <!-- 付款人：从活动参与人员中单选 -->
      <view wx:if="{{aaMembers.length > 0}}" class="form-item">
        <view class="label">付款人</view>
        <picker
          mode="selector"
          range="{{aaMembers}}"
          range-key="name"
          value="{{aaPayerIndex}}"
          bindchange="onAAPayerChange"
        >
          <view class="picker">
            {{aaPayerName || '请选择付款人'}}
          </view>
        </picker>
      </view>

      <!-- 参与人：活动参与人员多选 -->
      <view wx:if="{{aaMembers.length > 0}}" class="form-item">
        <view class="label">参与人（多选）</view>
        <view class="participants-header">
          <button size="mini" type="default" bindtap="onSelectAllParticipants">
            全选
          </button>
        </view>
        <checkbox-group bindchange="onAAParticipantsChange">
          <label
            wx:for="{{aaMembers}}"
            wx:key="name"
            class="checkbox-item"
          >
            <checkbox value="{{item.name}}" checked="{{item.checked}}" />
            <text class="checkbox-label">{{item.name}}</text>
          </label>
        </checkbox-group>
      </view>
    </view>

    <view class="form-item">
      <view class="label">支出事项</view>
      <input
        class="input"
        placeholder="例如：聚餐、房费、门票等"
        value="{{billItem}}"
        bindinput="onBillItemInput"
      />
    </view>

    <view class="form-item">
      <view class="label">支出总金额（元）</view>
      <input
        class="input"
        type="digit"
        placeholder="例如：300"
        value="{{billAmount}}"
        bindinput="onBillAmountInput"
      />
    </view>

    <button class="btn primary" bindtap="submitBill">保存并计算结算</button>

    <view class="divider"></view>

    <view class="section-title">本次结算结果</view>
    <view wx:if="{{settlements.length === 0}}" class="empty-text">
      提交一条账单后，这里会显示"谁给谁多少钱"
    </view>
    <view wx:else>
      <view
        wx:for="{{settlements}}"
        wx:key="index"
        class="list-item"
      >
        <view class="list-title">
          {{item.from}} → {{item.to}}：{{item.amount}} 元
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 当日结算单（日期维度汇总） -->
    <view class="section-title">当日结算单</view>
    <view wx:if="{{!selectedActivity}}">
      <view class="empty-text">请选择活动后查看当日汇总。</view>
    </view>
    <view wx:elif="{{!dailySummary || dailySummary.totalAmount === 0}}">
      <view class="empty-text">该日期暂无记账记录。</view>
    </view>
    <view wx:else>
      <view class="summary-header">
        <view class="list-title">日期：{{dailySummary.date}}</view>
        <view class="list-sub">总支出：{{dailySummary.totalAmount}} 元</view>
      </view>
      <view
        wx:for="{{dailySummary.members}}"
        wx:key="name"
        class="list-item"
      >
        <view class="list-title">{{item.name}}</view>
        <view class="list-sub">{{item.summaryText}}</view>
      </view>
    </view>
  </view>
</view>
