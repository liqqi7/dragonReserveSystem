page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 32rpx;
}

.result-box {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  min-height: 200rpx;
}

.result-text {
  font-size: 28rpx;
  color: #333;
  white-space: pre-line;
  line-height: 1.6;
}

.btn {
  width: 100%;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.danger {
  background-color: #fa5151;
  color: #ffffff;
}

.btn.danger[disabled] {
  background-color: #ccc;
  color: #999;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #fa5151;
  margin-top: 24rpx;
}
