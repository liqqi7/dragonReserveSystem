page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.auth-card {
  margin-top: 120rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 32rpx;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  margin-bottom: 24rpx;
}

.btn {
  width: 100%;
  margin-top: 8rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
