<view class="container">
  <view class="card auth-card">
    <view class="title">龙城冒险者工会预约系统</view>
    <view class="subtitle">请填写您的邀请码获取访问权限</view>

    <input
      class="input"
      placeholder="请输入邀请码"
      password="true"
      value="{{inviteCodeInput}}"
      bindinput="onInviteCodeInput"
    />

    <button class="btn primary" bindtap="checkInvite">进入工会</button>
    <view class="tip">请联系柜台小姐获取您的邀请码🌹</view>
  </view>
</view>
