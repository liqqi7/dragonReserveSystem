page {
  background-color: #f5f5f5;
}

.container {
  padding: 24rpx;
}

.center-box {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn {
  width: 100%;
  padding: 18rpx 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  border: none;
}

.btn.primary {
  background-color: #007aff;
  color: #ffffff;
}

.btn.default {
  background-color: #f0f0f0;
  color: #333;
}

.btn.danger {
  background-color: #fa5151;
  color: #ffffff;
}

.profile-box {
  margin-top: 24rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.userid {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.section {
  margin-top: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 0 24rpx 12rpx;
}

.cell {
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.cell-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.cell-desc {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.cell-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.bottom-area {
  margin-top: 40rpx;
}

/* 弹窗样式，复用活动管理的结构 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 32rpx;
  font-weight: 600;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 24rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  border-top: 1rpx solid #eee;
  gap: 16rpx;
}

.modal-footer .btn {
  flex: 1;
  margin: 0;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  padding: 0;
  margin: 0;
  border: none;
  background: none;
}

.input {
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

