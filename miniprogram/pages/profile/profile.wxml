<view class="container">
  <view class="profile-box">
    <view class="profile-header">
      <image wx:if="{{hasUser}}" class="avatar" src="{{user.avatarUrl || '/images/default-avatar.svg'}}" mode="aspectFill" binderror="onProfileAvatarError" />
      <view wx:else class="avatar placeholder"></view>
      <view class="info">
        <view class="nickname">
          {{hasUser ? (user.nickname || '未命名成员') : '神秘冒险者'}}
        </view>
        <view class="userid">
          <block wx:if="{{hasUser}}">
            公会 ID：{{user.userIdShort}}
          </block>
          <block wx:else>
            登录后可查看对应工会活动
          </block>
        </view>
      </view>
      <view wx:if="{{hasUser}}" class="header-actions">
        <view
          class="icon-btn"
          bindtap="openEditModal"
        >
          <image class="icon-img" src="/images/icon-profile-edit.svg" mode="aspectFit" />
        </view>
        <view
          class="icon-btn"
          bindtap="logout"
        >
          <image class="icon-img" src="/images/icon-profile-logout.svg" mode="aspectFit" />
        </view>
      </view>
      <view
        wx:else
        class="icon-btn"
        bindtap="startRegister"
      >
        <image class="icon-img" src="/images/icon-profile-login.svg" mode="aspectFit" />
      </view>
    </view>

    <!-- 仅已登录用户展示访问权限模块 -->
    <view wx:if="{{hasUser}}" class="section">
      <view class="section-title">访问权限</view>
      <view wx:if="{{isGuest}}" class="cell">
        <view class="cell-title">当前为游客，无法查看相关活动数据</view>
        <button class="btn primary small" bindtap="openPermissionModal">获取权限</button>
      </view>
      <view wx:else class="cell">
        <view class="cell-title">已获取访问权限</view>
        <button class="btn default small" bindtap="removePermission">删除权限</button>
      </view>
    </view>

  </view>

  <!-- 获取权限弹窗 -->
  <view wx:if="{{showPermissionModal}}" class="modal-overlay" bindtap="closePermissionModal">
    <view class="modal-content" catchtap="stopTap">
      <view class="modal-header">
        <text>获取权限</text>
        <text class="close-btn" bindtap="closePermissionModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <view class="label">请输入邀请码</view>
          <input
            class="input"
            password
            placeholder="请联系工会柜台获取邀请码🌹"
            value="{{permissionInput}}"
            bindinput="onPermissionInput"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn default" bindtap="closePermissionModal">取消</button>
        <button class="btn primary" bindtap="submitPermission">确认</button>
      </view>
    </view>
  </view>

  <!-- 编辑资料弹窗：昵称 + 微信头像 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="closeEditModal">
    <view class="modal-content" catchtap="stopTap">
      <view class="modal-header">
        <text>修改个人资料</text>
        <text class="close-btn" bindtap="closeEditModal">×</text>
      </view>

      <view class="modal-body">
        <view class="form-item avatar-form-row">
          <view class="label">头像</view>
          <view class="avatar-edit-wrap">
            <button class="avatar-edit-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
              <image wx:if="{{editAvatarUrl}}" class="avatar-edit-img" src="{{editAvatarUrl}}" mode="aspectFill" />
              <view wx:else class="avatar-edit-placeholder">选择头像</view>
            </button>
          </view>
        </view>
        <view class="form-item">
          <view class="label">昵称</view>
          <input
            type="text"
            class="input"
            placeholder="请输入昵称"
            value="{{editNickname}}"
            bindinput="onInputNickname"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn default" bindtap="closeEditModal">取消</button>
        <button class="btn primary" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>
