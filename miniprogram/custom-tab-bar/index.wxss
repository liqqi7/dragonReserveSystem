.tab-bar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32px;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  pointer-events: none;
}

.tab-bottom-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(82px + env(safe-area-inset-bottom));
  /* 与设计稿一致：Linear，0% #fff 0%，100% #fff 60%（竖直方向由上到下） */
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.6) 100%
  );
  pointer-events: none;
}

.tab-items-wrap {
  position: relative;
  display: flex;
  align-items: center;
  width: 90.256vw;
  height: 58px;
  padding: 4px;
  box-sizing: border-box;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  box-shadow:
    0 0 6px rgba(0, 0, 0, 0.06),
    inset 0 1px 2px #ffffff,
    inset 0 -1px 2px rgba(0, 0, 0, 0.02);
  pointer-events: auto;
}

.tab-indicator {
  position: absolute;
  left: 4px;
  width: calc((100% - 8px) / 4);
  height: 50px;
  border-radius: 999px;
  background-color: rgba(0, 0, 0, 0.06);
  pointer-events: none;
  transition:
    transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
    background-color 180ms ease,
    box-shadow 180ms ease;
  will-change: transform;
}

/* 页面 onShow 权威对齐：无过渡，避免与点击预滑动叠成双段动画 */
.tab-indicator-snap {
  transition: none !important;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 50px;
  border-radius: 999px;
  gap: 2px;
  position: relative;
}

.tab-icon-img {
  width: 24px;
  height: 24px;
  display: block;
}

.tab-icon-svg {
  width: 24px;
  height: 24px;
  display: block;
  position: relative;
  background-color: #1a191a;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 24px 24px;
}

.tab-icon-svg-active {
  background-color: #ff001f;
}

.tab-icon-calendar-wrap,
.tab-icon-calendar-wrap.tab-icon-svg-active {
  background-color: transparent;
}

.tab-icon-calendar-shape {
  position: absolute;
  inset: 0;
  background-color: #1a191a;
  -webkit-mask: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M21.9 4H2.1C1.49249 4 1 4.53726 1 5.2V20.8C1 21.4627 1.49249 22 2.1 22H21.9C22.5075 22 23 21.4627 23 20.8V5.2C23 4.53726 22.5075 4 21.9 4Z' fill='black' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3Cpath d='M6 2L6 6' stroke='black' stroke-width='1.5' stroke-linecap='round'/%3E%3Cpath d='M18 2L18 6' stroke='black' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E") center / 24px 24px no-repeat;
  mask: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M21.9 4H2.1C1.49249 4 1 4.53726 1 5.2V20.8C1 21.4627 1.49249 22 2.1 22H21.9C22.5075 22 23 21.4627 23 20.8V5.2C23 4.53726 22.5075 4 21.9 4Z' fill='black' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3Cpath d='M6 2L6 6' stroke='black' stroke-width='1.5' stroke-linecap='round'/%3E%3Cpath d='M18 2L18 6' stroke='black' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E") center / 24px 24px no-repeat;
}

.tab-icon-calendar-wrap.tab-icon-svg-active .tab-icon-calendar-shape {
  background-color: #ff001f;
}

.tab-icon-calendar-line {
  position: absolute;
  left: 6px;
  height: 1.5px;
  border-radius: 999px;
  background-color: #ffffff;
}

.tab-icon-calendar-line-top {
  top: 10.25px;
  width: 7px;
}

.tab-icon-calendar-line-bottom {
  top: 16.25px;
  width: 12px;
}

.tab-icon-ranking {
  -webkit-mask: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='13' y='1' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='13' y='13' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='1' y='1' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='1' y='13' width='10' height='10' rx='2' fill='black'/%3E%3C/svg%3E") center / 24px 24px no-repeat;
  mask: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='13' y='1' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='13' y='13' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='1' y='1' width='10' height='10' rx='2' fill='black'/%3E%3Crect x='1' y='13' width='10' height='10' rx='2' fill='black'/%3E%3C/svg%3E") center / 24px 24px no-repeat;
}

.tab-label {
  font-size: 10px;
  color: #1a191a;
  line-height: 12px;
}

.tab-label-active {
  color: #ff001f;
  font-weight: 500;
}

