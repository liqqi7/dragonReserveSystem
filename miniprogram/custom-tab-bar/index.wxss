.tab-bar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  pointer-events: none;
}

.tab-bottom-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(48px + env(safe-area-inset-bottom));
  /* 与设计稿一致：Linear，0% #fff 0%，100% #fff 60%（竖直方向由上到下） */
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.6) 100%
  );
  pointer-events: none;
}

.tab-items-wrap {
  position: relative;
  display: flex;
  align-items: center;
  width: 263px;
  height: 62px;
  padding: 4px;
  box-sizing: border-box;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: inset 0 -1px 2px rgba(0, 0, 0, 0.12), inset 0 1px 1px #fff;
  pointer-events: auto;
}

.tab-indicator {
  position: absolute;
  left: 4px;
  width: 85px;
  height: 54px;
  border-radius: 999px;
  background-color: rgba(0, 0, 0, 0.06);
  pointer-events: none;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 85px;
  height: 54px;
  border-radius: 999px;
  gap: 4px;
  position: relative;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

.tab-label {
  font-size: 10px;
  color: #1a191a;
  line-height: 1;
}

.tab-label-active {
  color: #ff001f;
  font-weight: 500;
}

.tab-create-fab {
  width: 62px;
  height: 62px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: inset 0 -1px 2px rgba(0, 0, 0, 0.12), inset 0 1px 1px #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.tab-create-icon {
  width: 32px;
  height: 32px;
}
